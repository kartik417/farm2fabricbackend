datasource db {
 provider = "postgresql"
 url      = env("DATABASE_URL")
}

generator client {
 provider = "prisma-client-js"
}

model User {
  id       Int      @id @default(autoincrement())
  name     String
  email    String   @unique
  password String
  role     Role

  products Product[]
  bids     Bid[]   @relation("ManufacturerBids")
}

model Product {
  id        Int      @id @default(autoincrement())
  title     String
  quantity  Int
  price     Float
  farmerId  Int
  createdAt DateTime @default(now())

  farmer    User     @relation(fields: [farmerId], references: [id])
  bids      Bid[]
  orders    Order[]   // 👈 ADD THIS
}

model Bid {
  id             Int      @id @default(autoincrement())
  price          Float
  quantity       Int
  productId      Int
  manufacturerId Int
  status         BidStatus @default(PENDING)
  createdAt      DateTime @default(now())

  product        Product  @relation(fields: [productId], references: [id])
  manufacturer   User     @relation("ManufacturerBids", fields: [manufacturerId], references: [id])
}
model Order {
  id             Int      @id @default(autoincrement())
  productId      Int
  bidId          Int
  farmerId       Int
  manufacturerId Int
  status         OrderStatus @default(CONFIRMED)
  createdAt      DateTime @default(now())

  product        Product  @relation(fields: [productId], references: [id])
}
model Shipment {
  id        Int      @id @default(autoincrement())
  orderId   Int
  location  String
  status    ShipmentStatus
  createdAt DateTime @default(now())
}

enum OrderStatus {
  CONFIRMED
  SHIPPED
  DELIVERED
}

enum ShipmentStatus {
  PICKED
  IN_TRANSIT
  DELIVERED
}
enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}
enum Role {
  FARMER
  MANUFACTURER
  BRAND
}